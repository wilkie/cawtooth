{
  "name": "cawtooth",
  "version": "0.1.0",
  "description": "A library for playing back retro chiptune music formats",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./worklet/opl": {
      "import": "./dist/worklet/opl-processor.js"
    },
    "./worklet/sid": {
      "import": "./dist/worklet/sid-processor.js"
    },
    "./worklet/psid": {
      "import": "./dist/worklet/psid-processor.js"
    },
    "./worklet/ay": {
      "import": "./dist/worklet/ay-processor.js"
    },
    "./worklet/sndh": {
      "import": "./dist/worklet/sndh-processor.js"
    },
    "./wasm/nuked-opl3.wasm": "./wasm/nuked-opl3.wasm",
    "./wasm/resid.wasm": "./wasm/resid.wasm",
    "./wasm/sidplay.wasm": "./wasm/sidplay.wasm",
    "./wasm/ayumi.wasm": "./wasm/ayumi.wasm",
    "./wasm/sndh.wasm": "./wasm/sndh.wasm"
  },
  "files": [
    "dist",
    "wasm"
  ],
  "scripts": {
    "build": "vite build && vite build --mode worklet && vite build --mode worklet-sid && vite build --mode worklet-psid && vite build --mode worklet-ay && vite build --mode worklet-sndh",
    "dev": "vite build --watch",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "test:watch": "node --experimental-vm-modules node_modules/jest/bin/jest.js --watch",
    "test:coverage": "node --experimental-vm-modules node_modules/jest/bin/jest.js --coverage",
    "typecheck": "tsc --noEmit",
    "build:wasm": "../../tools/build-wasm.sh",
    "prepublishOnly": "pnpm build"
  },
  "keywords": [
    "chiptune",
    "audio",
    "music",
    "retro",
    "playback",
    "opl2",
    "opl3",
    "adlib"
  ],
  "license": "GPL-3.0-or-later",
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "^22.19.17",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.5",
    "typescript": "^5.7.3",
    "vite": "^6.4.2",
    "vite-plugin-dts": "^4.5.4"
  }
}
