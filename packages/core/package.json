{
  "name": "cawtooth",
  "version": "0.1.0",
  "description": "A library for playing back retro chiptune music formats",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./wasm/nuked-opl3.wasm": "./wasm/nuked-opl3.wasm"
  },
  "files": [
    "dist",
    "wasm"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "typecheck": "tsc --noEmit",
    "build:wasm": "../../tools/build-wasm.sh",
    "prepublishOnly": "pnpm build"
  },
  "keywords": [
    "chiptune",
    "audio",
    "music",
    "retro",
    "playback",
    "opl2",
    "opl3",
    "adlib"
  ],
  "license": "GPL-3.0-or-later",
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "^22.19.17",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.5",
    "tsup": "^8.3.5",
    "typescript": "^5.7.3"
  }
}
