{
  "name": "@cawtooth-tests/e2e",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "End-to-end Playwright tests that exercise the full audio worklet path against real Chromium.",
  "scripts": {
    "test": "playwright test",
    "test:headed": "playwright test --headed",
    "test:ui": "playwright test --ui",
    "install-browsers": "playwright install chromium",
    "harness:dev": "vite --config harness/vite.config.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "cawtooth": "workspace:*"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0",
    "@types/node": "^22.10.0",
    "typescript": "^5.7.3",
    "vite": "^6.0.0"
  }
}
